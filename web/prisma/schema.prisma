// 老师端业务库。SQLite 单文件 / WAL 与 akapen-backend 的 grading.db 相同思路；
// 通过 docker volume `./web/data:/app/data` 持久化。
//
// 业务边界（与 akapen-backend 完全解耦）：
// - akapen-backend 只看 GradingTask 那一维度（task_id + result + status），
//   不关心 Class/Student/Question 等业务实体。
// - 我们这里也不存 OCR / 评分中间产物——akapen webhook 回来后直接落 GradingResult JSON。

generator client {
  provider      = "prisma-client-js"
  // alpine 22 自带 openssl 3.x；同时列 x86_64 / arm64 让 M 系 Mac docker-desktop
  // 与 x86_64 ECS 通用一份 schema、一次生成。"native" 留给开发机（Mac/Linux）。
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("teacher") // 留 enum 余地：teacher / admin
  createdAt    DateTime @default(now())

  classes  Class[]
  batches  HomeworkBatch[]
  settings WebSettings?
}

model Class {
  id        String          @id @default(cuid())
  name      String
  school    String?
  ownerId   String
  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  students  Student[]
  batches   HomeworkBatch[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([ownerId])
}

model Student {
  id          String       @id @default(cuid())
  classId     String
  externalId  String        // 学号
  name        String
  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions Submission[]
  createdAt   DateTime     @default(now())

  @@unique([classId, externalId])
  @@index([classId])
}

model HomeworkBatch {
  id        String     @id @default(cuid())
  classId   String
  ownerId   String
  title     String     // "9月第一次作文"
  notes     String?    // 给批改者的整体说明
  dueDate   DateTime?
  class     Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  owner     User       @relation(fields: [ownerId], references: [id])
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([classId])
  @@index([ownerId])
}

model Question {
  id          String       @id @default(cuid())
  batchId     String
  index       Int           // 第几题，UI 排序 + 学生上传时选择
  prompt      String        // 题干，会作为 question_context 送 akapen
  rubric      String?       // 评分要点 / 标准答案，可选
  maxScore    Float        @default(100)
  batch       HomeworkBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  submissions Submission[]
  createdAt   DateTime     @default(now())

  @@unique([batchId, index])
  @@index([batchId])
}

model Submission {
  id         String        @id @default(cuid())
  questionId String
  studentId  String
  imagePaths String        // JSON array，相对 web/data/uploads/
  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradings   GradingTask[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([questionId, studentId])
  @@index([questionId])
  @@index([studentId])
}

/// 老师端持久化的批改 / 转写配置。
///
/// 设计：每个 User 一行（owner = 老师本人），不和 Class / Batch 绑定 ——
/// 同一老师在不同班级 / 批次里大概率想用同一份模型 + prompt。需要按批次微调时，
/// 后续可以加 Question.gradingOverrideJson 单独 override 单题。
///
/// **不要**把 API key 存在这里：DashScope key 留给 backend 的 .env，
/// web 永远只通过 ProviderOverrides 把"模型 + prompt + 行为开关"递过去，
/// backend 自己用配好的 key 调 LLM。
model WebSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 批改主路径
  gradingProvider   String  @default("qwen")
  gradingModel      String  @default("qwen3-vl-plus")
  enableSingleShot  Boolean @default(true)
  gradingWithImage  Boolean @default(true)
  gradingThinking   Boolean @default(false)

  // OCR 路径（two-step 模式才用得到）
  ocrProvider String @default("qwen")
  ocrModel    String @default("qwen3-vl-plus")

  // Prompts —— 留 NULL 意味"用 backend 默认"，这样老师不填的字段会 fallback
  // 到 prompts/*.md。前端上限 16K（与 backend ProviderOverrides 一致）。
  ocrPrompt        String?
  gradingPrompt    String?
  singleShotPrompt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GradingTask {
  id             String     @id @default(cuid())
  submissionId   String
  // akapen 那边的 task_id（POST /v1/grading-tasks 返回）；网络断开时可能为 null
  akapenTaskId   String?    @unique
  // 我们生成的幂等键：submissionId + ":r" + revision
  // 同一份 Submission 多次重批就 revision++，老 GradingTask 留作历史
  idempotencyKey String     @unique
  revision       Int        @default(1)
  // 状态机：
  // pending   -- 已创建但还没成功 POST 给 akapen
  // queued    -- 已 POST，akapen 给了 task_id
  // running   -- 中台 worker 正在跑（轮询时映射 fetching/preprocessing/ocr/grading）
  // succeeded -- 中台回调说成功，result 已落库
  // failed    -- 中台回调说失败，errorCode/Message 已落库
  status         String     @default("pending")
  result         String?    // 完整 GradingResult JSON 字符串
  finalScore     Float?     // 抽出来方便排序 / 筛选
  // LLM 实际用的满分（与 GradingResult.max_score 同源）。Question.maxScore 是
  // 老师建题时填的"期望满分"，但实际 max 由批改 prompt 决定，UI 显示优先用这个，
  // 跑完批改才填；老题 / 跑挂的任务为 null，UI fallback 到 question.maxScore。
  maxScore       Float?
  reviewFlag     Boolean    @default(false)
  errorCode      String?
  errorMessage   String?
  attempts       Int        @default(0)
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([submissionId])
  @@index([status])
  @@index([akapenTaskId])
}
