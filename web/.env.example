# SQLite 业务库（与 backend 的 grading.db 完全独立，互不感知）
DATABASE_URL=file:./data/web.db

# NextAuth.js secret（>= 32 字符随机串，用 openssl rand -base64 32 生成）
AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# ⚠ 必填：老师**从浏览器访问**这台服务的完整 URL（不是容器内部的）。
# - 本地 docker 自测：http://localhost:3000
# - 公网 IP 直访：    http://<ECS-公网-IP>:3000
# - 域名 + HTTPS：    https://akapen.example.com
# 错填会导致登录后跳到错误的 host（典型症状：手机访问后地址栏变成 localhost）。
NEXTAUTH_URL=http://localhost:3000

# akapen 中台地址：
# - 同机 docker-compose：http://backend:8000（service 名，走 docker DNS，零带宽）
# - 跨机部署：https://your-akapen.example.com
AKAPEN_BASE_URL=http://backend:8000

# akapen 端配的某个 API_KEYS 里的 secret（X-API-Key 鉴权）
AKAPEN_API_KEY=replace-me

# 给 akapen 的 webhook 用，必须与 backend 的 .env 中 WEBHOOK_SECRET 一致
WEBHOOK_SECRET=must-equal-backend-WEBHOOK_SECRET

# akapen 容器从 docker DNS 拉图用，必须可由 backend 容器解析
# - 同机 compose：http://web:3000
# - 跨机 / 反代：换成 backend 能访问到的 URL（注意 hairpin 陷阱见 docs/）
WEB_PUBLIC_BASE_URL=http://web:3000

# 给图片 URL 签 HMAC 用，独立于 AUTH_SECRET / WEBHOOK_SECRET，
# 防止 web 自己生成的图片签名串穿越其他子系统。≥ 32 字符。
IMAGE_URL_SECRET=replace-me-32-char-min

# 单张上传图片大小上限（字节）。akapen 那边的 MAX_IMAGE_BYTES 默认 8MB，保持一致
MAX_UPLOAD_BYTES=8388608

# 一份 Submission 最多接几张图（akapen 单 task 上限是 8）
MAX_IMAGES_PER_SUBMISSION=8
