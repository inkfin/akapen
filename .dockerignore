# 让构建上下文尽量小：业务只关心 core/ + backend/（含 backend/prompts/） + requirements.txt
# 千万别把 data/ 或 dataset/ 拷进镜像 —— 那是宿主机持久化数据 / 测试图片

# Python / venv
.venv
.venv*
venv
__pycache__
**/__pycache__
*.py[cod]
*.pyo
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# Git / IDE / OS
.git
.gitignore
.gitattributes
.github
.idea
.vscode
.cursor
.cursorignore
.cursorrules
.DS_Store
Thumbs.db

# 本仓的运行数据 / 测试集 / 日志
data
dataset
logs
*.log
*.db
*.db-wal
*.db-shm

# 文档（除了 README/AGENTS 外的，都不需要进镜像）
docs
PLAN_*.md

# 模式 A 离线 Gradio 入口，中台镜像不需要
demo

# pyproject.toml / uv.lock 仅本地 uv 用，Docker 走 requirements.txt
pyproject.toml
uv.lock

# 构建产物
build
dist
*.tar
*.tgz

# 环境配置（敏感）
.env
.env.*
!.env.example

# Docker 自身
Dockerfile
docker-compose.yml
.dockerignore

# 脚本（不需要进镜像，本地跑就行）
scripts
