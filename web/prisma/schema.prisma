// 老师端业务库。SQLite 单文件 / WAL 与 akapen-backend 的 grading.db 相同思路；
// 通过 docker volume `./web/data:/app/data` 持久化。
//
// 业务边界（与 akapen-backend 完全解耦）：
// - akapen-backend 只看 GradingTask 那一维度（task_id + result + status），
//   不关心 Class/Student/Question 等业务实体。
// - 我们这里也不存 OCR / 评分中间产物——akapen webhook 回来后直接落 GradingResult JSON。

generator client {
  provider      = "prisma-client-js"
  // alpine 22 自带 openssl 3.x；同时列 x86_64 / arm64 让 M 系 Mac docker-desktop
  // 与 x86_64 ECS 通用一份 schema、一次生成。"native" 留给开发机（Mac/Linux）。
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("teacher") // 留 enum 余地：teacher / admin
  createdAt    DateTime @default(now())

  classes  Class[]
  batches  HomeworkBatch[]
  settings WebSettings?
}

model Class {
  id        String          @id @default(cuid())
  name      String
  school    String?
  ownerId   String
  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  students  Student[]
  batches   HomeworkBatch[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([ownerId])
}

model Student {
  id          String       @id @default(cuid())
  classId     String
  externalId  String        // 学号
  name        String
  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions Submission[]
  createdAt   DateTime     @default(now())

  @@unique([classId, externalId])
  @@index([classId])
}

model HomeworkBatch {
  id        String     @id @default(cuid())
  classId   String
  ownerId   String
  title     String     // "9月第一次作文"
  notes     String?    // 给批改者的整体说明
  // 作业学科（语文 / 英语 / 数学 ...），用于拼作业级上下文。
  batchSubject   String?
  // 作业目标（本次想考查什么能力），给 prompt 注入背景但不直接参与打分。
  batchObjective String?
  dueDate   DateTime?
  class     Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  owner     User       @relation(fields: [ownerId], references: [id])
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([classId])
  @@index([ownerId])
}

model Question {
  id      String @id @default(cuid())
  batchId String
  index   Int // 第几题，UI 排序 + 学生上传时选择
  prompt  String // 题干，会作为 question_context 送 akapen

  /// 是否需要打分。true = 走给分细则评分；false = 只批注，模型不输出
  /// final_score / max_score / dimension_scores（适合开放作文 / 写作辅导）。
  ///
  /// 之前是用"rubric 是否为空"隐式推断 —— 改成显式 boolean 后：
  /// 1) 状态可观察（DB / API / UI 一致），UI 能区分"应打分但 LLM 漏给"和"题本身不打分"；
  /// 2) 允许"打分但 rubric 暂存草稿"或"暂时关掉打分但保留 rubric"的中间态；
  /// 3) 成绩页 SQL hot query 直接 `WHERE requireGrading = true`，不用解析空串。
  ///
  /// **不变式**：requireGrading=true 时 rubric 必须非空（前后端双层校验）。
  requireGrading Boolean @default(true)

  /// 本题的**给分细则**：满分多少、给分点、扣分项。
  /// `requireGrading=true` 时**必填**；`=false` 时可以留 NULL 也可以留草稿（用 toggle 控制）。
  /// 全局 grading prompt 模板里的 `{rubric}` 占位符会被替换成这段文字；
  /// 满分由 LLM 根据 rubric 字面识别（"本题满分 30 分"），实际用的 max 回填到 GradingTask.maxScore。
  rubric String?

  /// 本题的**修改意见指南**：希望模型给学生写哪类反馈、关注哪些方面、用什么语气。
  /// 与 `rubric` 相互独立 —— rubric 控"打不打分 / 怎么打分"，feedbackGuide
  /// 控"怎么写 feedback"。
  /// **留空** = 用通用默认指南（关注内容 / 结构 / 语言 / 语法的常规修改建议）。
  /// **非空** = 用这段指引；可以写"用鼓励性语气"、"重点指出语法错误"、
  /// "按段落给意见"等具体要求。
  feedbackGuide String?

  /// 高级：单题自定义"批改 prompt（两步模式）"。
  /// 留 NULL = 用 WebSettings 的全局 gradingPrompt（替换 {rubric} 后送 LLM）；
  /// 非空 = **整段覆盖**全局 prompt，不再走 {rubric} 替换。
  customGradingPrompt String?

  /// 高级：单题自定义 single-shot prompt（视觉一次过）。同上规则。
  customSingleShotPrompt String?

  /// 单题覆盖思考开关（可空 = 继承 WebSettings.gradingThinking）。
  /// 推荐字面值：force_on / force_off。
  thinkingOverride String?

  /// 是否要求模型在 feedback 外额外给一份"修改后的范文"。
  provideModelAnswer Boolean @default(false)

  /// 范文生成要求（可空）：如"给 2 版不同风格范文"、"保留原文核心意象"等。
  modelAnswerGuide String?

  batch       HomeworkBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  submissions Submission[]
  createdAt   DateTime      @default(now())

  @@unique([batchId, index])
  @@index([batchId])
}

model Submission {
  id         String        @id @default(cuid())
  questionId String
  studentId  String
  imagePaths String        // JSON array，相对 web/data/uploads/
  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradings   GradingTask[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([questionId, studentId])
  @@index([questionId])
  @@index([studentId])
}

/// 老师端持久化的批改 / 转写配置。
///
/// 设计：每个 User 一行（owner = 老师本人），不和 Class / Batch 绑定 ——
/// 同一老师在不同班级 / 批次里大概率想用同一份模型 + prompt。需要按批次微调时，
/// 后续可以加 Question.gradingOverrideJson 单独 override 单题。
///
/// **不要**把 API key 存在这里：DashScope key 留给 backend 的 .env，
/// web 永远只通过 ProviderOverrides 把"模型 + prompt + 行为开关"递过去，
/// backend 自己用配好的 key 调 LLM。
model WebSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 批改主路径。default 跟 web/lib/actions/settings.ts:FALLBACK 保持一致。
  // Qwen 3.5+ 主线 plus/flash/max 默认就是多模态（详见 core/providers/qwen.py:is_vision_model）。
  gradingProvider   String  @default("qwen")
  gradingModel      String  @default("qwen3.6-plus")
  enableSingleShot  Boolean @default(true)
  gradingWithImage  Boolean @default(true)
  gradingThinking   Boolean @default(false)

  // OCR 路径（two-step 模式才用得到）
  ocrProvider String @default("qwen")
  ocrModel    String @default("qwen3.6-plus")

  // Prompts —— 留 NULL 意味"用 backend 默认"，这样老师不填的字段会 fallback
  // 到 backend/prompts/*.md。前端上限 16K（与 backend ProviderOverrides 一致）。
  ocrPrompt        String?
  gradingPrompt    String?
  singleShotPrompt String?

  /// 全局默认「修改意见 / feedback 指南」。三层回落：
  /// Question.feedbackGuide（题目级） > 这个（老师全局） > model-catalog.ts:DEFAULT_FEEDBACK_GUIDE（硬编码兜底）
  /// 留 NULL = 用硬编码默认（覆盖内容 / 结构 / 语言 / 语法的常规修改建议）。
  defaultFeedbackGuide String?

  /// 老师级默认人设（只跟 user 走，不跟作业/题目走）。
  defaultPersona String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GradingTask {
  id             String     @id @default(cuid())
  submissionId   String
  // 父任务（用于追问/重生范文形成 revision 时间线）。
  parentId       String?
  parent         GradingTask?  @relation("GradingTaskParent", fields: [parentId], references: [id], onDelete: SetNull)
  children       GradingTask[] @relation("GradingTaskParent")
  // akapen 那边的 task_id（POST /v1/grading-tasks 返回）；网络断开时可能为 null
  akapenTaskId   String?    @unique
  // 我们生成的幂等键：submissionId + ":r" + revision
  // 同一份 Submission 多次重批就 revision++，老 GradingTask 留作历史
  idempotencyKey String     @unique
  revision       Int        @default(1)
  // 状态机：
  // pending   -- 已创建但还没成功 POST 给 akapen
  // queued    -- 已 POST，akapen 给了 task_id
  // running   -- 中台 worker 正在跑（轮询时映射 fetching/preprocessing/ocr/grading）
  // succeeded -- 中台回调说成功，result 已落库
  // failed    -- 中台回调说失败，errorCode/Message 已落库
  status         String     @default("pending")
  // 高层模式：grade（常规）/ revise（追问、范文重生都走 revise 管道）
  mode           String     @default("grade")
  // 动作语义：grade / followup / model_answer_regen（用于历史筛选）
  actionType     String     @default("grade")
  // 老师追问指令（可空）：仅 revise 场景会写。
  teacherInstruction String?
  // 追问返回的 prompt 优化建议（可空 JSON 文本），老师确认后才应用到 Question。
  promptSuggestion String?
  result         String?    // 完整 GradingResult JSON 字符串
  finalScore     Float?     // 抽出来方便排序 / 筛选
  // LLM 实际用的满分（与 GradingResult.max_score 同源）。
  // 来源：题目的 rubric 里写的"本题满分 X 分"被 LLM 读到后回填。
  // 还没批改完 / 任务跑挂了 = null，UI 这时只显示 finalScore（不再有 question 占位满分）。
  maxScore       Float?
  reviewFlag     Boolean    @default(false)
  errorCode      String?
  errorMessage   String?
  attempts       Int        @default(0)
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([submissionId])
  @@index([parentId])
  @@index([status])
  @@index([actionType])
  @@index([akapenTaskId])
}
