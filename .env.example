# 复制本文件为 .env 并填入你的 API Key
# 也可以在网页 UI 的「设置」Tab 里填，写到 .env 启动后会自动加载
# Provider / 模型不在这里配，统一在 UI 的「设置」Tab 用下拉选

# ============= 模式 A & B 共用：LLM provider Key =============

# 阿里云百炼 / DashScope（Qwen 多模态，默认 OCR + 批改都用它）
DASHSCOPE_API_KEY=
# 默认中国区（北京）；海外可改 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 仅当本服务部署在阿里云 ECS 且与 DashScope 同 region 时设 true，会切到内网 endpoint
# (https://dashscope-vpc.aliyuncs.com/...)，不占公网带宽。跨 region 设 true 反而会失败。
USE_VPC_ENDPOINT=false

# Gemini（备选）
GEMINI_API_KEY=

# Anthropic Claude（备选批改）
ANTHROPIC_API_KEY=

# ============= 模式 B 专用：批改任务中台（python -m backend.app）=============

# REST API 鉴权：``name:secret``，逗号分隔多个；secret 至少 16 字符
# 示例：API_KEYS=akapen:dGVzdC1zZWNyZXQtMzItY2hhci1taW5pbXVtLWxlbmd0aA==
API_KEYS=

# Webhook HMAC-SHA256 共享密钥；前端校验签名用同一份
WEBHOOK_SECRET=

# 并发 / 带宽（默认是 2C2G + 公网 3 Mbps 优化值）
MAX_CONCURRENCY=8
BANDWIDTH_KBPS=2400

# 单任务 wall-clock 超时（秒）
TASK_TIMEOUT_SEC=300

# 单图原图体积上限（字节，默认 8MB）；multipart / URL 拉图都按这个判
MAX_IMAGE_BYTES=8388608

# 一个任务最多带几页（多页作文）
MAX_IMAGES_PER_TASK=8

# 数据 / 上传目录（默认 ./data；docker 部署可以挂卷到这里）
# BACKEND_DATA_DIR=/data

# 监听地址 / 端口
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
